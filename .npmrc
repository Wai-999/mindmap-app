# next-auth's optional peer dependency wants nodemailer@^7 (for its own unused Email
# provider) while this app depends directly on nodemailer@^9 for its own SMTP
# password-reset emails — a real version mismatch, but on an optional peer that's
# never actually exercised, so overriding it is safe rather than downgrading a real
# dependency. Without this, a plain `npm install` (e.g. Vercel's build step) fails.
legacy-peer-deps=true
