# Database (SQLite for local dev — see README for the PostgreSQL production swap)
DATABASE_URL="file:./dev.db"

# Auth.js / NextAuth v5 — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-32-byte-base64-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional future OAuth providers (not wired up yet, schema already supports adding them)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: enables real-time collaboration (Liveblocks). Leave unset to run fully
# solo — the app degrades gracefully with no collaboration UI at all. Get a secret
# key from https://liveblocks.io/dashboard/apikeys
# LIVEBLOCKS_SECRET_KEY=
