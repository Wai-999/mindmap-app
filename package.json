    "@xyflow/react": "^12.11.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-hierarchy": "^3.1.2",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.22.0",
    "nanoid": "^5.1.16",
    "next": "15.5.19",
    "next-auth": "^5.0.0-beta.31",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.80.0",
